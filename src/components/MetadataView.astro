---
// Main-column body of the metadata page, used by /data/metadata (Extended/Base,
// from baked data) and /annual-checklist/{year}/metadata (SSR-fetched). The
// short reference sections (version, license, publisher) live in the right
// column — see MetadataAside.astro.
import { md } from '@lib/md';
interface Release {
  key: number | string;
  title?: string;
  citation?: string;
  description?: string;
  creator?: { label: string }[];
}
interface Props {
  cur: Release;
  /** API base for the BibTeX link. */
  apiBase: string;
}
const { cur, apiBase } = Astro.props;
---

<h2>Abstract</h2>
<!-- description is markdown (links, emphasis); render it to HTML -->
<div set:html={md(cur.description)} />

<h2>Recommended citation</h2>
<div id="bibtex" style="float: right;">
  <a href={`${apiBase}/dataset/${cur.key}.bib`}>
    <img src="/images/logos/bibtex_logo.png" style="height: 32px;" alt="BibTeX" />
  </a>
</div>
<!-- citation is CSL HTML (a <div class="csl-entry">…</div>), so render it raw -->
<div set:html={cur.citation ?? ''} />
<p>
  Please also read the
  <a href="/howto/cite">recommended citations for individual datasets contributing to the Catalogue of Life.</a>
</p>

<h3>Authors</h3>
<div id="authors">
  <ul>
    {cur.creator?.map((a) => <li set:html={a.label} />)}
  </ul>
</div>
