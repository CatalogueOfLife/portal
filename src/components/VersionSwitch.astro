---
// Version switcher for the metadata page: pick which COL release's metadata to
// view. Selecting navigates to that version's metadata URL (which also sets the
// active version for the rest of the site) and remembers the pick.
import { versions } from '@data/versions';

interface Props {
  /** Label of the version this page currently shows (e.g. "Extended"). */
  currentLabel?: string;
}
const { currentLabel = 'Extended' } = Astro.props;

const metaHref = (v: (typeof versions)[number]) =>
  v.kind === 'base' ? '/data/metadata?v=br' : v.kind === 'annual' ? `/annual-checklist/${v.year}/metadata` : '/data/metadata';
---

<div class="version-switch">
  <span class="version-switch__label">COL version</span>
  <button type="button" class="version-switch__toggle" aria-haspopup="true" aria-expanded="false">
    <span class="version-switch__current">{currentLabel}</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M7 10l5 5 5-5z" /></svg>
  </button>
  <ul class="version-switch__menu" hidden>
    {
      versions.map((v) => (
        <li class={v.label === currentLabel ? 'version-switch__active' : ''}>
          <a href={metaHref(v)}>
            <span class="version-switch__opt">{v.label}</span>
            {v.version && <span class="version-switch__ver">{v.version}</span>}
          </a>
        </li>
      ))
    }
  </ul>
</div>

<script>
  // The menu items link to each version's metadata page, which is itself
  // version-specific — so the header records the active version from the URL on
  // arrival. This script only opens/closes the dropdown.
  const root = document.querySelector('.version-switch');
  const toggle = root?.querySelector<HTMLButtonElement>('.version-switch__toggle');
  const menu = root?.querySelector<HTMLUListElement>('.version-switch__menu');
  if (root && toggle && menu) {
    const close = () => {
      menu.setAttribute('hidden', '');
      toggle.setAttribute('aria-expanded', 'false');
    };
    toggle.addEventListener('click', () => {
      if (menu.hasAttribute('hidden')) {
        menu.removeAttribute('hidden');
        toggle.setAttribute('aria-expanded', 'true');
      } else {
        close();
      }
    });
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) close();
    });
  }
</script>

<style>
  .version-switch {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 20px;
  }
  .version-switch__label {
    font-weight: 600;
    color: #555;
  }
  .version-switch__toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    padding: 4px 10px;
    border: 1px solid #ccc;
    border-radius: 4px;
    background: #fff;
    color: #333;
    cursor: pointer;
    font-size: 0.95rem;
  }
  .version-switch__toggle:hover {
    background: #f2f2f2;
  }
  .version-switch__menu {
    position: absolute;
    z-index: 20;
    left: 0;
    top: 2.6rem;
    min-width: 240px;
    margin: 0;
    padding: 4px 0;
    list-style: none;
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 4px;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.14);
  }
  .version-switch__menu li {
    margin: 0;
  }
  .version-switch__menu a {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    padding: 7px 14px;
    color: #333;
    white-space: nowrap;
  }
  .version-switch__menu a:hover {
    background: #f7f7f7;
  }
  .version-switch__active a {
    font-weight: 600;
  }
  .version-switch__ver {
    color: #888;
    font-size: 0.85rem;
  }
</style>
