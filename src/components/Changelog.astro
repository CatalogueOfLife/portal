---
import { changelogEntries } from '@data/changelog';
import { numf } from '@lib/numf';

const longDate = (s?: string) =>
  s ? new Date(s).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const cbk = 'https://www.checklistbank.org/dataset';
---

<div id="changes">
  {
    changelogEntries.map((log) => (
      <Fragment>
        <h2 id={`r-${log.rel.dataset.alias}`}>
          <a href={`${cbk}/${log.rel.key}`}>{log.rel.dataset.alias}</a>
        </h2>
        <p>
          <span class="date">{longDate(log.rel.dataset.created)}</span> build from{' '}
          <span class="stats">{numf(log.rel.srcCnt as number)}</span> sources
          {log.rel.publisher && log.rel.publisher.length > 0 && (
            <Fragment>
              {' '}
              and <span class="stats">{numf(log.rel.publisher.length)}</span> publisher
            </Fragment>
          )}
          .<br />
          <span class="stats">{numf(log.rel.metrics.taxaByRankCount.family)}</span> families {log.diffFamily},{' '}
          <span class="stats">{numf(log.rel.metrics.taxaByRankCount.genus)}</span> genera {log.diffGenus} and{' '}
          <span class="stats">{numf(log.rel.metrics.taxaByRankCount.species)}</span> accepted species {log.diffSpecies}.
        </p>

        {log.prev && (
          <p>
            Previous version: <a href={`#r-${log.prev.dataset.alias}`}>{log.prev.dataset.alias || log.prev.dataset.version}</a>
          </p>
        )}

        {log.hasChange ? (
          <Fragment>
            <p>Source changes:</p>
            <p>
              <ul>
                {log.added.map((src) => (
                  <li>
                    <span class="add">+</span>{' '}
                    <a href={`${cbk}/${log.rel.key}/source/${src.key}`}>{src.alias || src.title}</a>
                  </li>
                ))}
                {log.removed.map((src) => (
                  <li>
                    <span class="remove">-</span>{' '}
                    <a href={`${cbk}/${log.prev?.key}/source/${src.key}`}>{src.alias || src.title}</a>
                  </li>
                ))}
              </ul>
            </p>
          </Fragment>
        ) : (
          <p>No sources changed.</p>
        )}

        {log.rel.extended &&
          (log.hasPubChange ? (
            <Fragment>
              <p>Publisher changes :</p>
              <p>
                <ul>
                  {log.padded.map((src) => (
                    <li>
                      <span class="add">+</span>{' '}
                      <a href={`${cbk}/${log.rel.key}/publisher/${src.id}`}>{src.title}</a>
                    </li>
                  ))}
                  {log.premoved.map((src) => (
                    <li>
                      <span class="remove">-</span>{' '}
                      <a href={`${cbk}/${log.prev?.key}/publisher/${src.id}`}>{src.title}</a>
                    </li>
                  ))}
                </ul>
              </p>
            </Fragment>
          ) : (
            <p>No publisher changed.</p>
          ))}
      </Fragment>
    ))
  }
</div>

<style>
  #changes h2 { margin-top: 32px; margin-bottom: 4px; }
  #changes h4 { margin-bottom: 2px; text-transform: none; }
  #changes p { margin-bottom: 6px; }
  #changes span.add { color: green; font-weight: bold; }
  #changes span.remove { color: red; font-weight: bold; }
  #changes ul { margin-left: 0.5rem; }
  #changes ul li { list-style-type: none; }
  .date { background-color: lightblue; color: black; padding: 2px 6px; }
  .stats { text-decoration: underline; color: black; }
</style>
