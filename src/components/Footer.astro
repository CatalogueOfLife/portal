---
import { site } from '../lib/site';
import { currentRelease } from '../data/releaseMetadata';

const year = new Date().getFullYear();
---

<div id="footer">
  <!-- Symmetric top row: Version (left, right-aligned) · square logo (centre) ·
       Catalogue of Life brand + socials (right, left-aligned). The two text
       blocks hug the central logo. -->
  <div class="footer-main">
    <div class="footer-col footer-version">
      <h4>Version</h4>
      <ul>
        <li><a href="/data/metadata">{currentRelease.version}</a></li>
        <li>Issued: <i>{currentRelease.issued}</i></li>
        <li>DOI: <a href={`https://doi.org/${currentRelease.doi}`}>{currentRelease.doi}</a></li>
        <li>
          ChecklistBank:
          <a href={`https://www.checklistbank.org/dataset/${currentRelease.key}/about`}>{currentRelease.key}</a>
        </li>
      </ul>
    </div>

    <a href="/" class="footer-logo-link" aria-label="Catalogue of Life — home">
      <img class="footer-square-logo" alt="Catalogue of Life" src="/images/logos/col_square_logo.jpg" />
    </a>

    <div class="footer-col footer-brand">
      <h4>Catalogue of Life</h4>
      <ul class="socials">
        <li>
          <a href={`https://www.linkedin.com/company/${site.linkedin_username}`} aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" role="img" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </li>
        <li>
          <a href={`https://www.facebook.com/${site.facebook_username}/`} aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" role="img" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
        </li>
        <li>
          <a href="/howto/contact" aria-label="Contact us by email">
            <svg viewBox="0 0 24 24" fill="currentColor" role="img" aria-hidden="true">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
            </svg>
          </a>
        </li>
      </ul>
      <div id="GCBR">
        <img alt="" src="/images/logos/GCBR-Logo-White.svg" class="cbdr-logo" />
        <div class="gcbr-text">is a Global Core Biodata Resource</div>
      </div>
    </div>
  </div>

  <div class="creativecommons">
    <p>
      © {year}, Catalogue of Life.<br />
      Unless otherwise indicated, all other content offered under <a
        rel="license"
        href="http://creativecommons.org/licenses/by/4.0/">Creative Commons Attribution 4.0 International License</a
      >.
    </p>
  </div>

  <div class="creativecommons footer-disclaimer">
    <h4>Disclaimer</h4>
    <p>
      The Catalogue of Life cannot guarantee the accuracy or completeness of the information in the Catalogue of Life.<br
      />
      Be aware that the Catalogue of Life is still incomplete and undoubtedly contains errors.<br />
      Catalogue of Life, nor any contributing database can be made liable for any direct or indirect damage arising out of
      the use of Catalogue of Life services.
    </p>
  </div>
</div>

<style>
  /* Version (left) · logo (exact centre) · brand (right). Equal-width side
     columns keep the logo centred; each text block hugs the central logo. */
  .footer-main {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    max-width: 60rem;
    margin: 0 auto;
    padding: 2.5rem 1rem 1.5rem;
  }
  .footer-version {
    flex: 1;
    text-align: right;
  }
  .footer-version ul {
    margin: 0;
    list-style: none;
  }
  .footer-logo-link {
    flex: none;
    display: block;
  }
  /* Enlarged logo; its bottom lines up with the Version block's last row. */
  .footer-square-logo {
    width: 127px;
    height: 127px;
    margin-top: 3px;
    border-radius: 4px;
    display: block;
  }
  .footer-brand {
    flex: 1;
    text-align: left;
  }
  .footer-brand h4 {
    margin: 0 0 0.5rem;
  }

  /* Social icons sit directly under the "Catalogue of Life" heading. */
  .socials {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    margin: 0 0 1rem;
    padding: 0;
    list-style: none;
  }
  .socials li {
    display: inline-flex;
    margin: 0;
  }
  /* #footer prefix beats the global `#footer ul a` colour rule. */
  #footer .socials a {
    display: inline-flex;
    color: #bbb;
    transition: color 0.2s linear;
  }
  #footer .socials a:hover {
    color: #f9ce06;
  }
  .socials svg {
    width: 24px;
    height: 24px;
  }

  /* GCBR badge: logo beside the strapline, under the social links. */
  #GCBR {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 0;
  }
  #GCBR .gcbr-text {
    text-align: left;
    font-size: 0.9rem;
    line-height: 1.2;
  }

  .footer-disclaimer p {
    max-width: 55rem;
    margin: 0 auto;
    font-size: 0.85rem;
    color: #777;
  }

  /* Stack on narrow screens: logo first, then the two blocks, all centred. */
  @media only screen and (max-width: 640px) {
    .footer-main {
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }
    .footer-logo-link {
      order: -1;
    }
    .footer-version,
    .footer-brand {
      text-align: center;
    }
    .socials,
    #GCBR {
      justify-content: center;
    }
  }
</style>
