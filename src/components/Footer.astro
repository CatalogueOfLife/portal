---
import { site } from '../lib/site';
import { currentRelease } from '../data/releaseMetadata';

const year = new Date().getFullYear();
---

<div id="footer">
  <div class="footer-main">
    <div class="footer-col footer-contact">
      <h4>Contact Us</h4>
      <ul class="socials">
        <li>
          <a href={`https://www.linkedin.com/company/${site.linkedin_username}`} aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" role="img" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </li>
        <li>
          <a href={`https://www.facebook.com/${site.facebook_username}/`} aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="currentColor" role="img" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
        </li>
        <li>
          <a href="/howto/contact" aria-label="Contact us by email">
            <svg viewBox="0 0 24 24" fill="currentColor" role="img" aria-hidden="true">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" />
            </svg>
          </a>
        </li>
      </ul>
    </div>

    <div class="footer-col footer-logo">
      <a href="/">
        <img alt="Catalogue of Life" src="/images/logos/col_square_logo.jpg" />
      </a>
    </div>

    <div class="footer-col footer-version">
      <h4>Version</h4>
      <ul>
        <li><a href="/data/metadata">{currentRelease.version}</a></li>
        <li>Issued: <i>{currentRelease.issued}</i></li>
        <li>DOI: <a href={`https://doi.org/${currentRelease.doi}`}>{currentRelease.doi}</a></li>
        <li>
          ChecklistBank:
          <a href={`https://www.checklistbank.org/dataset/${currentRelease.key}/about`}>{currentRelease.key}</a>
        </li>
      </ul>
    </div>
  </div>

  <div class="creativecommons">
    <p>
      © {year}, Catalogue of Life.<br />
      Unless otherwise indicated, all other content offered under <a
        rel="license"
        href="http://creativecommons.org/licenses/by/4.0/">Creative Commons Attribution 4.0 International License</a
      >.
    </p>
  </div>

  <div class="creativecommons" id="GCBR">
    <img alt="" src="/images/logos/GCBR-Logo-White.svg" class="cbdr-logo" />
    <div class="gcbr-text">
      <a href="/about/catalogueoflife">Catalogue of Life</a> <br />is a Global Core Biodata Resource
    </div>
  </div>

  <div class="creativecommons footer-disclaimer">
    <h4>Disclaimer</h4>
    <p>
      The Catalogue of Life cannot guarantee the accuracy or completeness of the information in the Catalogue of Life.<br
      />
      Be aware that the Catalogue of Life is still incomplete and undoubtedly contains errors.<br />
      Catalogue of Life, nor any contributing database can be made liable for any direct or indirect damage arising out of
      the use of Catalogue of Life services.
    </p>
  </div>
</div>

<style>
  /* Compact three-column top row: Contact (left) · square logo (centred) ·
     Version (right). The logo is sized to the Version block and the row is
     vertically centred so it lines up rather than towering above the text. */
  .footer-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    max-width: 60rem;
    margin: 0 auto;
    padding: 2.5rem 1rem 1.5rem;
  }
  .footer-col {
    flex: 1 1 0;
  }
  .footer-contact {
    text-align: left;
  }
  .footer-version {
    text-align: right;
  }
  .footer-logo {
    flex: 0 0 auto;
    text-align: center;
  }
  .footer-logo img {
    width: 140px;
    height: 140px;
    border-radius: 4px;
    display: inline-block;
  }
  .footer-version ul {
    margin: 0;
    list-style: none;
  }

  /* Contact icons in a row: LinkedIn · Facebook · email (→ /contact). */
  .socials {
    display: flex;
    gap: 0.85rem;
    align-items: center;
    margin: 0.5rem 0 0;
    padding: 0;
    list-style: none;
  }
  .socials li {
    display: inline-flex;
    margin: 0;
  }
  /* #footer prefix beats the global `#footer ul a` colour rule. */
  #footer .socials a {
    display: inline-flex;
    color: #bbb;
    transition: color 0.2s linear;
  }
  #footer .socials a:hover {
    color: #f9ce06;
  }
  .socials svg {
    width: 24px;
    height: 24px;
  }

  /* GCBR badge: logo beside strapline, centred. */
  #GCBR {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  #GCBR .gcbr-text {
    text-align: left;
  }

  .footer-disclaimer p {
    max-width: 55rem;
    margin: 0 auto;
    font-size: 0.85rem;
    color: #777;
  }

  /* Stack the three columns on narrow screens. */
  @media only screen and (max-width: 640px) {
    .footer-main {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1.5rem;
    }
    .footer-contact,
    .footer-version {
      text-align: center;
    }
    .socials {
      justify-content: center;
    }
  }
</style>
