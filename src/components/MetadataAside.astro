---
// Right-column sidebar for the metadata page: the version panel (shared with the
// homepage/metrics), a Links section for the release identifiers, the license,
// the publisher and the contact. The long-form content (abstract, citation,
// authors) stays in the main column — see MetadataView.astro.
import VersionInfo from './VersionInfo.astro';
interface Contact {
  name?: string;
  organisation?: string;
  email?: string;
  city?: string;
  country?: string;
  address?: string;
}
interface Release {
  key: number | string;
  alias?: string;
  issued?: string;
  doi?: string;
  issn?: string;
  publisher?: { label: string } | null;
  contact?: Contact | null;
}
interface Props {
  cur: Release;
  /** API base for the BibTeX link. */
  apiBase: string;
}
const { cur, apiBase } = Astro.props;
const contact = cur.contact;
const contactName = contact?.organisation || contact?.name;
const contactPlace = contact?.address || [contact?.city, contact?.country].filter(Boolean).join(', ');
---

<VersionInfo alias={cur.alias} issued={cur.issued} doi={cur.doi} bibHref={`${apiBase}/dataset/${cur.key}.bib`} />

<h3>Links</h3>
<div>
  ChecklistBank: <a href={`https://www.checklistbank.org/dataset/${cur.key}/about`}>{cur.key}</a><br />
  {cur.issn && (<>ISSN: <a href={`https://portal.issn.org/resource/ISSN/${cur.issn}`}>{cur.issn}</a></>)}
</div>

<h3>License</h3>
<p>
  <a href="https://creativecommons.org/licenses/by/4.0/">
    <img src="/images/cc-by-icon.svg" alt="Creative Commons Attribution 4.0 International" />
  </a>
</p>

{cur.publisher && (<><h3>Publisher</h3><p set:html={cur.publisher.label} /></>)}

{contact && (contactName || contact.email) && (
  <>
    <h3>Contact</h3>
    <div>
      {contactName && <>{contactName}<br /></>}
      {contactPlace && <>{contactPlace}<br /></>}
      {contact.email && <a href={`mailto:${contact.email}`}>{contact.email}</a>}
    </div>
  </>
)}

<style>
  /* The sidebar column isn't `.prose`, so give its section headings the same
     breathing room the main-column headings get. */
  h3 {
    margin-top: 1.6rem;
  }
</style>
