---
import { render } from 'astro:content';
import { getPosts } from '@lib/posts';
import NewsLayout from '@layouts/NewsLayout.astro';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { year: post.year, month: post.month, day: post.day, slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post.entry);
const dateStr = post.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<NewsLayout title={post.title}>
  <div class="row">
    <div class="large-12 columns">
      <div class="mod modBlogPost big">
        <div class="content">
          <p class="info">
            <span>{dateStr}</span>
            {post.author && (<Fragment> / <span>by {post.author}</span></Fragment>)}
          </p>
          <h3><a href={post.url}>{post.title}</a></h3>
          {post.images.length > 0 && (
            <div class="images">
              {post.images.map((img) => (<div class="image"><img alt="" src={`/${img}`} /></div>))}
            </div>
          )}
          <Content />
        </div>
      </div>
      <div class="two spacing"></div>
    </div>
  </div>
</NewsLayout>
