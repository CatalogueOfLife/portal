---
import Content from '@layouts/Content.astro';
import SourceListIsland from '@components/islands/SourceListIsland.tsx';
import { datasetKey } from '@data/releaseMetadata';

const fm = {
  title: 'Source datasets',
  tagline: 'A Global Network of Taxonomic Contributors',
  section_id: 'data',
  toc: false,
  imageUrl: '/images/species/Nyctalus_leisleri.jpg',
  imageCaption:
    '_Nyctalus leisleri_ (Kuhl, 1817) - [Photo CC BY Sylvain Eichhorn](https://www.inaturalist.org/observations/297984115)',
};
---

<Content frontmatter={fm}>
  <div class="row" style="background: white">
    <div id="sources" class="catalogue-of-life">
      <SourceListIsland client:only="react" datasetKey={String(datasetKey)} />
    </div>
  </div>
</Content>

<style is:global>
  /* Base release: hide the source list's "Include XR" toggle (the only
     checkbox in the list) since the Base has no Extended data. The toggle is
     wrapped in .sources-base only when ?v=br is active (see SourceListIsland).
     The count beside it then spans the full row. */
  .sources-base .ant-col:has(.ant-checkbox) {
    display: none;
  }
  .sources-base .ant-col:has(.ant-checkbox) ~ .ant-col {
    flex: 0 0 100%;
    max-width: 100%;
  }
</style>
