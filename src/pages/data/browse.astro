---
import Content from '@layouts/Content.astro';
import TreeIsland from '@components/islands/TreeIsland.tsx';
import { datasetKey, metadata } from '@data/releaseMetadata';

const fm = {
  title: 'Browse',
  tagline: "Explore the world's species through their classification",
  section_id: 'data',
  imageUrl: '/images/species/Patiriella_calcar.jpg',
  imageCaption:
    '_Patiriella calcar_ (Lamarck, 1816) - [Photo CC By Donald Hobern](https://www.flickr.com/photos/dhobern/42551733071)',
};
---

<Content frontmatter={fm} colBrowser>
  <h1>Browse the Catalogue of Life</h1>
  <p>
    Use this tree to explore the full classification from the current
    <a href="/data/metadata">version {metadata.current.version}</a> of the Catalogue of Life. The
    <strong>Find taxon</strong> field allows for direct access using any name known to COL.
  </p>
  <div class="row" style="background: white; margin-top: 0; margin-bottom: 0">
    <div id="tree" class="catalogue-of-life">
      <TreeIsland client:only="react" datasetKey={String(datasetKey)} showTreeOptions type="project" />
    </div>
  </div>
</Content>
