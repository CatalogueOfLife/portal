---
import Base from '@layouts/Base.astro';
import TaxonIsland from '@components/islands/TaxonIsland.tsx';
import { metadata } from '@data/releaseMetadata';
import { colFetch } from '@lib/colApi';
import { site } from '@lib/site';
import { resolveVersion } from '@lib/version';
import { extendedKey } from '@data/versions';

// On-demand SSR (replaces the backend Freemarker PortalPageRenderer for taxa):
// server-render the SEO head + JSON-LD, then hydrate the interactive island.
export const prerender = false;

const { id } = Astro.params;
const api = metadata.api;
// Version from the URL: ?v=br -> Base, otherwise the default Extended release.
// The id is fetched against that release; redirects keep the version query.
const ver = resolveVersion(Astro.url.pathname, Astro.url.search);
const K = ver.datasetKey;
const vq = ver.linkQuery;

// Fetch the full usage info. The /taxon/{id}/info endpoint also returns
// synonyms (status != accepted) with their accepted usage — redirect those to
// the accepted taxon (the old PortalPageRenderer.SynonymException behaviour).
const ACCEPTED = new Set(['accepted', 'provisionally accepted']);
let info: any = null;
// Base is a subset of Extended: a base id may be missing here yet exist in
// Extended — when that happens we offer a link to the Extended page.
let inExtended = false;
const infoRes = await colFetch(`${api}/dataset/${K}/taxon/${id}/info`);
if (infoRes.ok) {
  info = await infoRes.json();
  const status = info?.usage?.status;
  // For synonyms the accepted usage hangs off usage.accepted (an object with
  // an id; tolerate a bare string too).
  const acc = info?.usage?.accepted;
  const acceptedId = typeof acc === 'string' ? acc : acc?.id;
  if (status && !ACCEPTED.has(status) && acceptedId) {
    return Astro.redirect(`/data/taxon/${acceptedId}${vq}`, 301);
  }
} else {
  const nu = await colFetch(`${api}/dataset/${K}/nameusage/${id}`);
  if (nu.ok) {
    const acceptedId = (await nu.json())?.accepted?.id;
    if (acceptedId) return Astro.redirect(`/data/taxon/${acceptedId}${vq}`, 301);
  }
  // Not found. TODO: render an archived-taxon tombstone once the public API
  // exposes archived-usage lookups (the old PortalPageRenderer.ArchivedException path).
  Astro.response.status = 404;
  if (ver.kind === 'base') {
    const ext = await colFetch(`${api}/dataset/${extendedKey}/taxon/${id}/info`);
    inExtended = ext.ok;
  }
}

const u = info?.usage;
const name = u?.name ?? {};
const sourceTitle = info?.source?.title;
const taxonUrl = `${site.url}/data/taxon/${id}`;
const logo = `${site.url}/images/col_square_logo.jpg`;

const title = u ? `${u.label} | COL` : 'Not found | COL';
const description = u
  ? `${u.label} in the Catalogue of Life${sourceTitle ? ` based on ${sourceTitle}` : ''}`
  : 'This name could not be found in the current Catalogue of Life.';

// Flatten the synonyms dict (homotypic/heterotypic/...) into one list.
const synonyms: any[] = info?.synonyms
  ? Object.values(info.synonyms).flatMap((v) => (Array.isArray(v) ? v : []))
  : [];
const vernaculars: any[] = info?.vernacularNames ?? [];
const classification: any[] = info?.classification ?? [];
const parent = classification.filter((c) => c.id !== id).pop();

const jsonLd: Record<string, unknown> | null = u
  ? {
      // Plain string context (not the array form): the array form is valid JSON-LD
      // but trips naive consumers that do `data['@context'].toLowerCase()`. CURIE
      // terms (dwc:) are expanded to full IRIs below so no prefix map is needed.
      '@context': 'https://schema.org/',
      '@id': taxonUrl,
      '@type': 'Taxon',
      additionalType: ['http://rs.tdwg.org/dwc/terms/Taxon', 'http://rs.tdwg.org/ontology/voc/TaxonConcept#TaxonConcept'],
      identifier: [
        { '@type': 'PropertyValue', name: 'dwc:taxonID', propertyID: 'http://rs.tdwg.org/dwc/terms/taxonID', value: id },
        { '@type': 'PropertyValue', name: 'col:ID', propertyID: 'http://catalogueoflife.org/terms/ID', value: id },
      ],
      name: u.label,
      scientificName: {
        '@type': 'TaxonName',
        name: name.scientificName,
        author: name.authorship,
        taxonRank: name.rank,
        ...(info.publishedIn?.citation ? { isBasedOn: { '@type': 'ScholarlyArticle', name: info.publishedIn.citation } } : {}),
      },
      ...(name.rank ? { taxonRank: [`${api}/vocab/rank/${name.rank}`, name.rank] } : {}),
      ...(synonyms.length
        ? {
            alternateName: synonyms.map((s) => s.label),
            alternateScientificName: synonyms.map((s) => ({
              '@type': 'TaxonName',
              name: s.name?.scientificName,
              author: s.name?.authorship,
              taxonRank: s.name?.rank,
            })),
          }
        : {}),
      ...(vernaculars.length
        ? { 'http://rs.tdwg.org/dwc/terms/vernacularName': vernaculars.map((v) => ({ '@language': v.language, '@value': v.name })) }
        : {}),
      ...(parent
        ? {
            parentTaxon: {
              '@id': `${site.url}/data/taxon/${parent.id}`,
              '@type': 'Taxon',
              name: parent.label ?? parent.name,
              identifier: [
                { '@type': 'PropertyValue', name: 'dwc:taxonID', propertyID: 'http://rs.tdwg.org/dwc/terms/taxonID', value: parent.id },
              ],
              ...(parent.rank ? { taxonRank: [`${api}/vocab/rank/${parent.rank}`, parent.rank] } : {}),
            },
          }
        : {}),
    }
  : null;
---

<Base title={title} description={description} noindex={!u || ver.kind === 'base'}>
  <Fragment slot="head">
    <meta property="og:title" content={title} />
    <meta property="og:url" content={taxonUrl} />
    <meta property="og:image" content={logo} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={logo} />
    <link rel="alternate" hreflang="en" href={taxonUrl} />
    <link rel="alternate" hreflang="x-default" href={taxonUrl} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </Fragment>

  <div class="row" style="background: white; margin-top: 20px; margin-bottom: 60px">
    {
      u ? (
        <div id="taxon" class="catalogue-of-life">
          <TaxonIsland
            client:only="react"
            datasetKey={String(K)}
            pageTitleTemplate="COL | __taxon__"
            showDistributionMap
            gbifChecklistKey="7ddf754f-d193-4cc9-b351-99906754a03b"
          />
        </div>
      ) : (
        <div class="row" style="padding: 40px 0">
          <div class="large-12 columns">
            <h2>Not found</h2>
            {inExtended ? (
              <Fragment>
                <p>
                  This taxon is not part of the <a href="/building/releases#base">Base release</a>, but it exists in the{' '}
                  <a href="/building/releases#extended">Extended release</a>.
                </p>
                <p><a href={`/data/taxon/${id}`}>View it in the Extended release →</a></p>
              </Fragment>
            ) : (
              <p>This name could not be found in the current Catalogue of Life. It may have been removed in a more recent release.</p>
            )}
            <p><a href="/data/search">Search the Catalogue of Life</a></p>
          </div>
        </div>
      )
    }
  </div>
</Base>
